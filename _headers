# Cloudflare Pages headers - CNX Cigars Lounge
# Security headers on every response; long cache for immutable assets.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Fonts: immutable, cache hard
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# CSS / JS: immutable, cache hard
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/scripts/*
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# Images: long cache
/images/*
  Cache-Control: public, max-age=2592000

# HTML: revalidate so content updates ship fast
/*.html
  Cache-Control: public, max-age=0, must-revalidate
